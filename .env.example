# Development mode - app runs with simulated data out of the box.
# Set to 'false' only when you have real HotPocket servers configured below.
VITE_MOCK_MODE=true

# HotPocket server URLs (only needed when VITE_MOCK_MODE=false)
# Replace with your actual server URLs in production
VITE_CONTRACT_URLS=wss://your-hotpocket-server-1.example/ws,wss://your-hotpocket-server-2.example/ws

# Optional convenience variables
VITE_HP_NODE_URL=
VITE_CONTRACT_ID=
